{
  "name": "nhfs",
  "version": "0.1.34",
  "description": "NHFS — A sleek HTTP file server for the web built with Next.js and HeroUI. (Alpha)",
  "private": false,
  "scripts": {
    "dev": " echo http://localhost:3000/test-dir/ && next dev --turbopack",
    "build": "next build --turbopack && npm run build:move",
    "build:move": "rm -rf dist && mv .next/standalone dist && cp -r public dist/ && cp -r .next/static dist/.next/ && rm -rf dist/node_modules",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format:check": "prettier .",
    "format": "prettier -w ."
  },
  "bin": {
    "nhfs": "bin.js"
  },
  "author": {
    "email": "alisanan9090@gmail.com",
    "name": "Ali Sanan",
    "url": "https://devshell.blog/about"
  },
